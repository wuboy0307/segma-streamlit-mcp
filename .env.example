# segma-streamlit-mcp 環境變數範例 / env template.
# 複製成 .env(已被 .gitignore 忽略,不會進 git)再填入你的值:
#   cp .env.example .env
# app 啟動時會讀這些;沒填的可在左側面板手動輸入。

# ── Segma MCP 連線 ────────────────────────────────────────────────
# 要連的 Segma MCP endpoint。二擇一:
#   SEGMA_MCP_URL 直接給完整 /mcp 位址;或
#   SEGMA_ACCESS_URL 給部署根位址,app 會自動推導 <url>/mcp。
SEGMA_MCP_URL=https://localhost:1443/mcp
# SEGMA_ACCESS_URL=https://<your-segma-host>

# 自簽憑證(本機 stack)要設 false 才連得上;正式環境用有效憑證時設 true。
SEGMA_MCP_VERIFY_TLS=false

# 注意:Bearer token(JWT)不是環境變數 —— 在 app 左側「Bearer token (JWT)」
# 欄位貼上。取得方式見 memory reference_segma_mcp_auth:
#   POST /api/auth/login → 回傳的 token。

# ── LLM(OpenAI 相容)────────────────────────────────────────────
# agent 用的 LLM。LLM_API_KEY 必填(沒填則在左側 LLM 設定面板輸入)。
LLM_API_KEY=
# 預設 gpt-4o;可換成任何 OpenAI 相容的 model 名。
LLM_MODEL=gpt-4o
# 留空 = 直連 OpenAI;要走 OpenAI 相容 proxy 時填它的 base_url。
LLM_BASE_URL=
# 單次回覆的 max_tokens 上限(預設 2048)。
LLM_MAX_TOKENS=2048

# ── UI ────────────────────────────────────────────────────────────
# 介面語言 zh / en(使用者仍可在畫面上切換)。
SEGMA_UI_LANG=zh
